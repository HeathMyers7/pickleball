<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Are We Pickling Today?</title>
  <meta name="description" content="Checks Tuesday 4–6pm weather in New Albany, OH and answers: Are we pickling today?" />
  <style>
    :root{
      --bg:#0b1220;
      --text:#e9eefc;
      --muted:#b8c2e0;
      --yes:#22c55e;
      --no:#ef4444;
      --warn:#f59e0b;
      --accent:#60a5fa;
      --shadow: 0 10px 30px rgba(0,0,0,.35);
      --radius: 18px;
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono","Courier New", monospace;
      --sans: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
    }
    *{box-sizing:border-box;}
    body{
      margin:0;
      font-family:var(--sans);
      background:
        radial-gradient(1200px 800px at 20% 10%, rgba(96,165,250,.25), transparent 60%),
        radial-gradient(900px 600px at 90% 0%, rgba(34,197,94,.18), transparent 55%),
        radial-gradient(800px 600px at 70% 90%, rgba(239,68,68,.16), transparent 60%),
        var(--bg);
      color:var(--text);
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
    }
    .wrap{ width:min(980px, 100%); }
    header{
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      gap:16px;
      margin-bottom:16px;
    }
    h1{
      margin:0;
      font-size: clamp(28px, 3.2vw, 44px);
      letter-spacing:-0.02em;
    }
    .subtitle{
      color:var(--muted);
      font-size:14px;
      margin-top:6px;
    }
    .grid{
      display:grid;
      grid-template-columns: 1.2fr .8fr;
      gap:16px;
    }
    @media (max-width: 880px){ .grid{ grid-template-columns: 1fr; } }
    .card{
      background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      border: 1px solid rgba(255,255,255,.12);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding:18px;
      backdrop-filter: blur(8px);
    }
    .status{
      display:flex;
      align-items:center;
      justify-content:center;
      flex-direction:column;
      gap:8px;
      padding:28px 18px;
    }
    .pill{
      font-family: var(--mono);
      font-size: 13px;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.12);
      color: var(--muted);
    }
    .big{
      font-size: clamp(56px, 7vw, 92px);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.04em;
      text-transform: uppercase;
    }
    .big.yes{ color: var(--yes); text-shadow: 0 0 22px rgba(34,197,94,.35); }
    .big.no{ color: var(--no);  text-shadow: 0 0 22px rgba(239,68,68,.35); }
    .big.unknown{ color: var(--warn); text-shadow: 0 0 22px rgba(245,158,11,.28); }

    .reason{
      color: var(--muted);
      font-size: 14px;
      text-align:center;
      max-width: 60ch;
    }
    .meta{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:12px;
      margin-top:12px;
      width:100%;
    }
    @media (max-width: 520px){ .meta{ grid-template-columns: 1fr; } }
    .kv{
      padding:12px;
      border-radius: 14px;
      background: rgba(0,0,0,.18);
      border: 1px solid rgba(255,255,255,.10);
    }
    .k{ color: var(--muted); font-size:12px; margin-bottom:6px; }
    .v{ font-size:14px; }

    a{ color: var(--accent); text-decoration: none; }
    a:hover{ text-decoration: underline; }

    .btn{
      background: rgba(96,165,250,.15);
      border: 1px solid rgba(96,165,250,.35);
      color: var(--text);
      padding:10px 12px;
      border-radius: 12px;
      cursor:pointer;
      font-weight: 600;
    }
    .btn:hover{ background: rgba(96,165,250,.22); }

    .smallbtn{
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.10);
      color: var(--muted);
      padding:8px 10px;
      border-radius: 12px;
      cursor:pointer;
      font-weight: 600;
      font-size: 12px;
    }
    .smallbtn:hover{ background: rgba(255,255,255,.08); }

    details{ margin-top: 12px; width:100%; }
    details > summary{
      cursor:pointer;
      color: var(--muted);
      font-size: 13px;
      list-style:none;
    }
    details > summary::-webkit-details-marker{ display:none; }

    .hint{
      margin-top:10px;
      padding:12px;
      border-radius: 14px;
      background: rgba(0,0,0,.16);
      border: 1px solid rgba(255,255,255,.10);
      color: var(--muted);
      font-size: 13px;
      line-height: 1.35;
      white-space: pre-wrap;
    }

    .footer{
      margin-top:14px;
      color: rgba(233,238,252,.72);
      font-size: 12px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      flex-wrap:wrap;
    }

    /* “relatively hidden” admin hotspot */
    #adminHotspot{
      position:fixed;
      right:10px;
      bottom:10px;
      width:22px;
      height:22px;
      border-radius: 8px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.10);
      opacity: .08;
      cursor:pointer;
      display:flex;
      align-items:center;
      justify-content:center;
      user-select:none;
      transition: opacity .15s ease, transform .15s ease;
    }
    #adminHotspot:hover{ opacity: .35; transform: scale(1.08); }

    .toast{
      position:fixed;
      left:50%;
      bottom:18px;
      transform:translateX(-50%);
      background: rgba(0,0,0,.55);
      border: 1px solid rgba(255,255,255,.12);
      color: var(--text);
      padding:10px 12px;
      border-radius: 12px;
      font-size: 12px;
      box-shadow: var(--shadow);
      opacity:0;
      pointer-events:none;
      transition: opacity .2s ease;
      max-width: min(520px, 92vw);
      text-align:center;
    }
    .toast.show{ opacity:1; }

    code{ font-family: var(--mono); font-size: 12px; }
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <div>
        <h1>Are We Pickling Today?</h1>
        <div class="subtitle">Auto-checks Tuesday play (4–6pm) based on New Albany, OH weather.</div>
      </div>
      <button id="refreshBtn" class="btn" title="Re-check weather">Refresh</button>
    </header>

    <div class="grid">
      <section class="card status" aria-live="polite">
        <div class="pill">Rule: Tuesday + nice weather 4–6pm</div>
        <div class="big unknown" id="answer">…</div>
        <div class="reason" id="reason">Checking forecast…</div>

        <div class="meta">
          <div class="kv">
            <div class="k">Location</div>
            <div class="v">7600 Bevelhymer Rd, New Albany, OH 43054</div>
          </div>
          <div class="kv">
            <div class="k">Equipment</div>
            <div class="v">No equipment needed.</div>
          </div>
          <div class="kv">
            <div class="k">Rules video</div>
            <div class="v">
              <a href="https://www.youtube.com/watch?v=pDDwZgepQeE" target="_blank" rel="noopener">
                Pickleball rules (YouTube)
              </a>
            </div>
          </div>
          <div class="kv">
            <div class="k">Last updated</div>
            <div class="v" id="updated">—</div>
          </div>
        </div>

        <details>
          <summary>Show decision details</summary>
          <div class="hint" id="detailsBox">—</div>
        </details>
      </section>

      <aside class="card">
        <h2 style="margin:0 0 8px 0; font-size:18px;">How it decides</h2>
        <div class="hint" style="white-space:normal;">
          <div style="margin-bottom:8px;">
            <b>YES</b> only when <b>today is Tuesday</b> and the forecast between <b>4–6pm</b> looks good.
          </div>
          <div style="margin-bottom:8px;">
            “Nice” is defined as:
            <ul style="margin:8px 0 0 18px; padding:0;">
              <li>precipitation probability ≤ <b>20%</b></li>
              <li>wind speed ≤ <b>20 mph</b></li>
              <li>temperature between <b>45°F</b> and <b>95°F</b></li>
              <li>weather code indicates clear/partly cloudy/overcast (no rain/snow)</li>
            </ul>
          </div>
          <div>
            You can tweak those thresholds in the script near <code>NICE_CRITERIA</code>.
          </div>
        </div>

        <div style="display:flex; gap:10px; margin-top:12px; flex-wrap:wrap;">
          <button class="smallbtn" id="copyLinkBtn" title="Copy this page URL">Copy page link</button>
          <button class="smallbtn" id="resetOverrideBtn" title="Clear any override">Clear override</button>
        </div>

        <details>
          <summary style="margin-top:12px;">Admin / Override (hidden)</summary>
          <div class="hint" style="white-space:normal;">
            <div style="margin-bottom:8px;">
              Hidden hotspot bottom-right (🥒). Click it <b>3 times</b>, enter password, flips YES↔NO.
            </div>
            <div>Keyboard shortcut: <code>Ctrl</code> + <code>Shift</code> + <code>O</code></div>
            <div style="margin-top:8px; color: rgba(233,238,252,.65);">
              Note: static site = client-side “password protection” (light deterrent).
            </div>
          </div>
        </details>

        <div class="footer">
          <span id="tzLabel">Timezone: —</span>
          <span style="opacity:.7;">Data: Open‑Meteo</span>
        </div>
      </aside>
    </div>
  </div>

  <div id="adminHotspot" title="(hidden) admin">🥒</div>
  <div class="toast" id="toast"></div>

<script>
(() => {
  // -------------------------------
  // CONFIG
  // -------------------------------
  const ADDRESS = "7600 Bevelhymer Rd, New Albany, OH 43054";

  // Fallback coordinates for New Albany, OH (used if geocoding fails)
  const FALLBACK_LOCATION = { name: "New Albany, OH", lat: 40.0812, lon: -82.8088, timezone: "America/New_York" };

  // Nice-weather thresholds (edit if desired)
  const NICE_CRITERIA = {
    maxPrecipProb: 20,     // %
    maxWindMph: 20,        // mph
    minTempF: 45,
    maxTempF: 95,
    allowedWeatherCodes: new Set([0, 1, 2, 3]) // 0 clear, 1-3 partly cloudy/overcast
  };

  // Password protection is client-side (static site).
  // Default password: PickleTime!
  // To change: replace ADMIN_PASSWORD_SHA256 with SHA-256 hash of your new password.
  const ADMIN_PASSWORD_SHA256 = "de6b1f6d5fdbf9b5be0fca1436cf7a1bc88b7b6ce1a25c1a6b0fbe1c3db0f8d0";

  // Storage keys
  const LS_FLIP = "pickling_override_flip"; // "true" / "false"

  // -------------------------------
  // ELEMENTS
  // -------------------------------
  const elAnswer  = document.getElementById("answer");
  const elReason  = document.getElementById("reason");
  const elUpdated = document.getElementById("updated");
  const elDetails = document.getElementById("detailsBox");
  const elTz      = document.getElementById("tzLabel");
  const toast     = document.getElementById("toast");

  document.getElementById("refreshBtn").addEventListener("click", () => init());
  document.getElementById("copyLinkBtn").addEventListener("click", async () => {
    try{
      await navigator.clipboard.writeText(location.href);
      showToast("Link copied.");
    } catch {
      showToast("Could not copy link (clipboard permissions).");
    }
  });
  document.getElementById("resetOverrideBtn").addEventListener("click", () => {
    localStorage.removeItem(LS_FLIP);
    showToast("Override cleared.");
    init();
  });

  // Hidden hotspot: click 3 times quickly to open admin
  const hotspot = document.getElementById("adminHotspot");
  let tapCount = 0;
  let tapTimer = null;

  hotspot.addEventListener("click", () => {
    tapCount++;
    clearTimeout(tapTimer);
    tapTimer = setTimeout(() => { tapCount = 0; }, 1200);
    if (tapCount >= 3){
      tapCount = 0;
      openAdmin();
    }
  });

  // Keyboard shortcut: Ctrl+Shift+O
  window.addEventListener("keydown", (e) => {
    if (e.ctrlKey && e.shiftKey && (e.key === "O" || e.key === "o")) openAdmin();
  });

  // -------------------------------
  // HELPERS
  // -------------------------------
  function showToast(msg){
    toast.textContent = msg;
    toast.classList.add("show");
    setTimeout(() => toast.classList.remove("show"), 2200);
  }

  async function sha256Hex(text){
    const enc = new TextEncoder().encode(text);
    const buf = await crypto.subtle.digest("SHA-256", enc);
    return [...new Uint8Array(buf)].map(b => b.toString(16).padStart(2,"0")).join("");
  }

  function setAnswer(text, kind){
    elAnswer.textContent = text;
    elAnswer.classList.remove("yes","no","unknown");
    elAnswer.classList.add(kind);
  }

  function fmtLocal(dt, tz){
    return new Intl.DateTimeFormat("en-US", {
      timeZone: tz,
      year:"numeric", month:"short", day:"2-digit",
      hour:"numeric", minute:"2-digit"
    }).format(dt);
  }

  function getWeekday(tz){
    return new Intl.DateTimeFormat("en-US", { timeZone: tz, weekday:"long" }).format(new Date());
  }

  function getISODate(tz){
    // YYYY-MM-DD in a specific timezone
    const parts = new Intl.DateTimeFormat("en-CA", { timeZone: tz, year:"numeric", month:"2-digit", day:"2-digit" }).formatToParts(new Date());
    const y = parts.find(p=>p.type==="year").value;
    const m = parts.find(p=>p.type==="month").value;
    const d = parts.find(p=>p.type==="day").value;
    return `${y}-${m}-${d}`;
  }

  function getOverrideFlip(){
    return localStorage.getItem(LS_FLIP) === "true";
  }
  function setOverrideFlip(val){
    localStorage.setItem(LS_FLIP, val ? "true" : "false");
  }
  function applyOverride(baseYes){
    return getOverrideFlip() ? !baseYes : baseYes;
  }

  function describeWeatherCode(code){
    const map = {
      0:"Clear", 1:"Mainly clear", 2:"Partly cloudy", 3:"Overcast",
      45:"Fog", 48:"Rime fog",
      51:"Light drizzle", 53:"Drizzle", 55:"Dense drizzle",
      56:"Freezing drizzle", 57:"Dense freezing drizzle",
      61:"Slight rain", 63:"Rain", 65:"Heavy rain",
      66:"Freezing rain", 67:"Heavy freezing rain",
      71:"Slight snow", 73:"Snow", 75:"Heavy snow", 77:"Snow grains",
      80:"Slight rain showers", 81:"Rain showers", 82:"Violent rain showers",
      85:"Slight snow showers", 86:"Heavy snow showers",
      95:"Thunderstorm", 96:"Thunderstorm with hail", 99:"Thunderstorm w/ heavy hail"
    };
    return map[code] ?? `Weather code ${code}`;
  }

  // -------------------------------
  // DATA FETCH (Open-Meteo)
  // -------------------------------
  async function geocodeAddress(){
    // Geocoding API: https://geocoding-api.open-meteo.com/v1/search?name=...
    const url = `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(ADDRESS)}&count=1&language=en&format=json`;
    const res = await fetch(url);
    if (!res.ok) throw new Error("Geocoding failed");
    const data = await res.json();
    if (!data.results || !data.results.length) return null;
    const r = data.results[0];
    return {
      name: r.name ? `${r.name}${r.admin1 ? ", " + r.admin1 : ""}` : FALLBACK_LOCATION.name,
      lat: r.latitude,
      lon: r.longitude,
      timezone: r.timezone || FALLBACK_LOCATION.timezone
    };
  }

  async function fetchForecast(loc){
    // Forecast API: https://api.open-meteo.com/v1/forecast
    const vars = [
      "temperature_2m",
      "precipitation_probability",
      "weather_code",
      "wind_speed_10m"
    ].join(",");

    const url = new URL("https://api.open-meteo.com/v1/forecast");
    url.searchParams.set("latitude", String(loc.lat));
    url.searchParams.set("longitude", String(loc.lon));
    url.searchParams.set("hourly", vars);
    url.searchParams.set("temperature_unit", "fahrenheit");
    url.searchParams.set("wind_speed_unit", "mph");
    url.searchParams.set("timezone", loc.timezone || "auto");
    url.searchParams.set("forecast_days", "1");

    const res = await fetch(url.toString());
    if (!res.ok) throw new Error("Forecast fetch failed");
    return res.json();
  }

  // -------------------------------
  // DECISION LOGIC
  // -------------------------------
  function evaluateNiceBetween4And6(forecast, tz){
    const isoDate = getISODate(tz);
    const times = forecast.hourly?.time || [];
    const temp  = forecast.hourly?.temperature_2m || [];
    const pop   = forecast.hourly?.precipitation_probability || [];
    const wcode = forecast.hourly?.weather_code || [];
    const wind  = forecast.hourly?.wind_speed_10m || [];

    // 4–6pm window: check 16:00 and 17:00 hours
    const targetTimes = [`${isoDate}T16:00`, `${isoDate}T17:00`];
    const rows = [];

    for (const tt of targetTimes){
      const i = times.indexOf(tt);
      if (i === -1) return { ok:false, reason:`No hourly forecast found for ${tt} in timezone ${tz}.` };
      rows.push({
        time: tt,
        tempF: temp[i],
        precipProb: pop[i],
        weatherCode: wcode[i],
        windMph: wind[i]
      });
    }

    const checks = rows.map(r => {
      const codeOk = NICE_CRITERIA.allowedWeatherCodes.has(Number(r.weatherCode));
      const popOk  = Number(r.precipProb) <= NICE_CRITERIA.maxPrecipProb;
      const windOk = Number(r.windMph)     <= NICE_CRITERIA.maxWindMph;
      const tempOk = Number(r.tempF) >= NICE_CRITERIA.minTempF && Number(r.tempF) <= NICE_CRITERIA.maxTempF;
      return { ...r, codeOk, popOk, windOk, tempOk, allOk: (codeOk && popOk && windOk && tempOk) };
    });

    return { ok:true, isoDate, checks, nice: checks.every(c => c.allOk) };
  }

  // -------------------------------
  // ADMIN / OVERRIDE
  // -------------------------------
  async function openAdmin(){
    const pw = prompt("Admin password:");
    if (pw === null) return;

    try{
      const hash = await sha256Hex(pw);
      if (hash !== ADMIN_PASSWORD_SHA256){
        showToast("Incorrect password.");
        return;
      }
      const flipped = !getOverrideFlip();
      setOverrideFlip(flipped);
      showToast(flipped ? "Override enabled (decision flipped)." : "Override disabled.");
      init();
    } catch (err){
      console.error(err);
      showToast("Password check failed.");
    }
  }

  // -------------------------------
  // MAIN
  // -------------------------------
  async function init(){
    setAnswer("…","unknown");
    elReason.textContent = "Checking forecast…";
    elDetails.textContent = "—";
    elUpdated.textContent = "—";

    let loc = FALLBACK_LOCATION;
    try{
      const g = await geocodeAddress();
      if (g) loc = g;
    } catch {
      // silent fallback
    }

    elTz.textContent = `Timezone: ${loc.timezone || "auto"}`;

    try{
      const forecast = await fetchForecast(loc);
      const tz = forecast.timezone || loc.timezone || "America/New_York";
      elTz.textContent = `Timezone: ${tz}`;

      const weekday = getWeekday(tz);
      const niceEval = evaluateNiceBetween4And6(forecast, tz);

      if (!niceEval.ok){
        setAnswer("NO","no");
        elReason.textContent = `Couldn’t evaluate 4–6pm forecast (${niceEval.reason}).`;
        elUpdated.textContent = fmtLocal(new Date(), tz);
        elDetails.textContent = niceEval.reason;
        return;
      }

      const baseYes  = (weekday === "Tuesday") && niceEval.nice;
      const finalYes = applyOverride(baseYes);
      const flip = getOverrideFlip();

      setAnswer(finalYes ? "YES" : "NO", finalYes ? "yes" : "no");

      const overrideNote = flip ? " (override active: flipped)" : "";

      if (finalYes){
        elReason.textContent = `Yep — looks like we’re pickling today. ${weekday} + nice 4–6pm weather${overrideNote}.`;
      } else {
        const dayNote = weekday !== "Tuesday" ? `Today is ${weekday}, not Tuesday.` : `Today is Tuesday.`;
        const weatherNote = niceEval.nice ? "Weather looks fine." : "Weather does not look nice enough 4–6pm.";
        elReason.textContent = `${dayNote} ${weatherNote}${overrideNote}`;
      }

      const lines = [];
      lines.push(`Date (local): ${niceEval.isoDate}`);
      lines.push(`Weekday: ${weekday}`);
      lines.push(`Base decision (no override): ${baseYes ? "YES" : "NO"}`);
      lines.push(`Override flip: ${flip ? "ON" : "OFF"}`);
      lines.push("");
      lines.push("4–6pm hourly checks:");
      for (const c of niceEval.checks){
        const time = c.time.split("T")[1];
        lines.push(`• ${time} — ${c.tempF}°F, wind ${c.windMph} mph, precip ${c.precipProb}% , ${describeWeatherCode(c.weatherCode)} => ${c.allOk ? "OK" : "NOT OK"}`);
      }
      lines.push("");
      lines.push(`Thresholds: precip≤${NICE_CRITERIA.maxPrecipProb}%, wind≤${NICE_CRITERIA.maxWindMph}mph, temp ${NICE_CRITERIA.minTempF}–${NICE_CRITERIA.maxTempF}°F, codes ${[...NICE_CRITERIA.allowedWeatherCodes].join(", ")}`);

      elDetails.textContent = lines.join("\n");
      elUpdated.textContent = fmtLocal(new Date(), tz);

    } catch (err){
      console.error(err);
      setAnswer("NO","no");
      elReason.textContent = "Could not fetch weather right now (network/API issue).";
      elUpdated.textContent = new Date().toLocaleString();
      elDetails.textContent = String(err);
      showToast("Weather check failed.");
    }
  }

  init();
})();
</script>
</body>
</html>
